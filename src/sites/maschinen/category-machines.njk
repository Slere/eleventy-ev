---
pagination:
    data: machines.list
    size: 1
    alias: machines
layout: layout/app.njk
eleventyComputed:
    title: "{{ machines.parent_category ~ ' - ' ~ machines.title | capitalize }}"
    permalink: "{{ machines.slug }}/"
---

<script type="text/javascript">
    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll('.embla').forEach((emblaRoot) => {
            const mainViewport = emblaRoot.querySelector('.embla__viewport')
            const thumbsViewport = emblaRoot.querySelector('.embla-thumbs__viewport')
            if (! mainViewport || ! thumbsViewport) 
                return
            
            const mainEmbla = EmblaCarousel(mainViewport, {
                loop: false,
                skipSnaps: false
            })
            const thumbsEmbla = EmblaCarousel(thumbsViewport, {
                draggable: false,
                containScroll: 'trimSnaps'
            })
            const thumbSlides = emblaRoot.querySelectorAll('.embla-thumbs__slide')
            // --- Sync thumbs → main
            thumbSlides.forEach((thumb, index) => {
                thumb.addEventListener('click', () => {
                    mainEmbla.scrollTo(index)
                })
            })
            // --- Sync main → thumbs
            const syncThumbs = () => {
                const selectedIndex = mainEmbla.selectedScrollSnap()
                thumbSlides.forEach((thumb) => {
                    thumb.classList.remove('embla-thumbs__slide--selected');
                    thumb.classList.replace('border-primary', 'border-transparent');
                    thumb.classList.replace('p-0.5', 'p-0');
                })
                const selectedThumb = thumbSlides[selectedIndex]
                if (! selectedThumb) 
                    return
                
                selectedThumb.classList.add('embla-thumbs__slide--selected');
                selectedThumb.classList.replace('border-transparent', 'border-primary');
                selectedThumb.classList.replace('p-0', 'p-0.5');
                thumbsEmbla.scrollTo(selectedIndex)
            }
            // Initial state
            syncThumbs()
            mainEmbla.on('select', syncThumbs).on('reInit', syncThumbs)
        })
    });
</script>
{% set crumbs = page.url | breadcrumbs %}
{% set idx = (crumbs | length) - 2 %}
{% if idx >= 0 %}
    {% set backUrl = crumbs[idx].url %}
{% else %}
    {% set backUrl = '/' %}
{% endif %}
{% set backUrl = backUrl | replaceAll(' ', '-') %}

<section class="pt-24 pb-10 section-gradient-light border-b border-border-light">
    <div class="max-w-8xl mx-auto px-6">
        <nav aria-label="breadcrumb">
            {%- from "components/breadcrumbs.njk" import breadcrumbs -%}
            {% set crumbs = page.url | breadcrumbs %}
            {{ breadcrumbs(crumbs) }}
        </nav>
    </div>
</section>

<section class="flex-1 bg-background">
    <div class="mx-auto">
        <div class="space-y-12 md:space-y-16 py-8 md:py-12">
            {% for product in machines.machines %}
                {% if product.url != page.url %}
                    <article class="group scroll-my-24 bg-background" id="{{ product.id }}">
                        <div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-10 gap-0 items-stretch overflow-hidden lg:max-w-8xl lg:mx-auto">
                            <div class="col-span-3 md:col-span-2 lg:col-span-6 flex min-w-0 flex-col gap-7 p-6 pb-8 md:p-6 lg:pr-10">
                                <div class="max-w-3xl">
                                    <h2 class="font-headline text-2xl font-semibold tracking-tight text-foreground-headline sm:text-3xl lg:text-4xl hyphens-auto break-words">
                                        {{ product.name | safe }}
                                    </h2>
                                    <p class="mt-4 max-w-2xl text-base leading-relaxed text-foreground-muted">
                                        {{ product.description | safe }}
                                    </p>
                                    {% if product.variants and product.variants.length > 0 %}
                                        <div class="mt-6 flex flex-col gap-3 border-l-2 border-primary/20 pl-4">
                                            <h3 class="text-xs font-semibold uppercase text-secondary-foreground">
                                                Ähnliche Maschinen
                                            </h3>
                                            <div class="flex flex-wrap gap-2">
                                                {% for variant in product.variants %}
                                                    {% set variant_machine = machines.byId[variant] %}
                                                    {% if variant_machine and variant_machine.name %}
                                                        <a href="{{ ("/" ~ variant_machine.category_slug ~ "#" ~ variant_machine.id) | url }}" class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card px-3 py-1.5 text-xs font-medium text-secondary-foreground transition-colors hover:border-primary/30 hover:text-primary">
                                                            {{ variant_machine.name }}
                                                            <svg
                                                                xmlns="http://www.w3.org/2000/svg"
                                                                width="24"
                                                                height="24"
                                                                viewBox="0 0 24 24"
                                                                fill="none"
                                                                stroke="currentColor"
                                                                stroke-width="2"
                                                                stroke-linecap="round"
                                                                stroke-linejoin="round"
                                                                class="lucide lucide-arrow-right size-3.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                                                            </svg>
                                                        </a>
                                                    {% endif %}
                                                {% endfor %}
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>

                                {% if product.images and product.images.length > 1 %}
                                    <div class="w-full">
                                        <div class="embla bg-transparent">
                                            <div class="embla__viewport overflow-hidden rounded-lg border border-border-light bg-secondary/75 shadow-card">
                                                <div class="embla__container flex touch-pan-y touch-pinch-zoom">
                                                    {% for image in product.images %}
                                                        <div class="embla__slide flex min-h-80 min-w-0 basis-full shrink-0 grow-0 items-center justify-center md:min-h-[28rem]">
                                                            <div class="w-full">
                                                                <img src="{{ image | url }}" alt="{{ product.name }}" class="mx-auto block max-h-[min(70vh,42rem)] w-full object-contain"/>
                                                            </div>
                                                        </div>
                                                    {% endfor %}
                                                </div>
                                            </div>
                                            <div class="embla-thumbs mt-3">
                                                <div class="embla-thumbs__viewport overflow-hidden">
                                                    <div class="embla-thumbs__container flex flex-row gap-2">
                                                        {% for image in product.images %}
                                                            <div class="embla-thumbs__slide flex w-24 aspect-[4/3] overflow-hidden border-2 border-transparent p-0 shrink-0 rounded-md bg-transparent transition-all shadow-soft md:w-28 lg:w-32">
                                                                <button
                                                                    type="button"
                                                                    aria-label="Bild {{ loop.index }} anzeigen"
                                                                    class="embla-thumbs__slide__number cursor-pointer bg-[url({{ image | url }})] bg-center bg-cover w-full h-full rounded-sm"></button>
                                                            </div>
                                                        {% endfor %}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                {% elif product.images and product.images.length == 1 %}
                                    <div class="w-full overflow-hidden rounded-lg border border-border-light bg-secondary/75 shadow-card">
                                        <div class="flex min-h-80 items-center justify-center md:min-h-[28rem]">
                                            <img src="{{ product.images[0] | url }}" alt="{{ product.name }}" class="max-h-[min(70vh,42rem)] w-full object-contain"/>
                                        </div>
                                    </div>
                                {% else %}
                                    <div class="w-full overflow-hidden">
                                        <div class="flex min-h-80 items-center justify-center">
                                            <img src="{{ "/assets/img/machines/placeholder.png" | url }}" alt="{{ product.name }}" class="h-28 w-28 object-contain opacity-80"/>
                                        </div>
                                    </div>
                                {% endif %}
                            </div>

                            <aside class="col-span-3 md:col-span-2 lg:col-span-4 flex h-full md:pt-4 md:pb-6 md:pl-4">
                                <div class="flex h-full w-full flex-col border-t border-border-light bg-card p-6 shadow-card md:rounded-tl-xl md:rounded-bl-xl md:border md:p-8 lg:mr-6 xl:max-w-xl">
                                    <div class="flex items-start justify-between gap-4 border-b border-border-light pb-5">
                                        <div>
                                            {% if product.manufacturer_logo %}
                                                <img src="{{ product.manufacturer_logo | url }}" alt="{{ product.manufacturer_name }}" class="max-h-12 w-auto max-w-32 object-contain"/>
                                            {% else %}
                                                <p class="font-semibold text-secondary-foreground">{{ product.manufacturer_name }}</p>
                                            {% endif %}
                                        </div>
                                    </div>

                                    {% if product.features_list and product.features_list.length > 0 %}
                                        <div class="py-6">
                                            <h3 class="mb-4 text-sm font-semibold uppercase text-secondary-foreground">
                                                Hauptmerkmale
                                            </h3>
                                            <ul class="space-y-3">
                                                {% for feat in product.features_list %}
                                                    <li class="flex gap-3 text-sm leading-snug text-foreground">
                                                        <span class="mt-0.5 flex size-5 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                                                            <svg
                                                                xmlns="http://www.w3.org/2000/svg"
                                                                width="24"
                                                                height="24"
                                                                viewBox="0 0 24 24"
                                                                fill="none"
                                                                stroke="currentColor"
                                                                stroke-width="2.5"
                                                                stroke-linecap="round"
                                                                stroke-linejoin="round"
                                                                class="lucide lucide-check size-3"><path d="M20 6 9 17l-5-5"/>
                                                            </svg>
                                                        </span>
                                                        <span>{{ feat | safe }}</span>
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                        </div>
                                    {% endif %}

                                    {% if product.manufacturer_information %}
                                        <div class="border-t border-border-light pt-5">
                                            <h3 class="mb-3 text-sm font-semibold uppercase text-secondary-foreground">
                                                Merkmale
                                            </h3>
                                            <div class="text-sm leading-relaxed text-foreground-muted">
                                                {{ product.manufacturer_information | safe }}
                                            </div>
                                        </div>
                                    {% endif %}

                                    {% if product.manufacturer_product_page %}
                                        <div class="mt-auto pt-6">
                                            <a href="{{ product.manufacturer_product_page | url }}" target="_blank" rel="noopener noreferrer" class="inline-flex w-full items-center justify-between gap-3 rounded-md border border-primary/20 bg-primary px-4 py-3 text-sm font-semibold text-primary-foreground shadow-button transition-all hover:bg-primary/90 hover:shadow-hover">
                                                <span>Weitere Infos beim Hersteller</span>
                                                <svg
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    width="24"
                                                    height="24"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="2.5"
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    class="lucide lucide-arrow-right size-4"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                                                </svg>
                                            </a>
                                        </div>
                                    {% endif %}
                                </div>
                            </aside>
                        </div>
                    </article>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</section>
