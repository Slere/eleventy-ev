---
title: Bereichsübersicht
layout: layout/app.njk
test_image: /assets/img/sectors/folienverpackung.jpg
---

<section class="pt-32 pb-16 section-gradient-light">
    <div class="max-w-8xl mx-auto px-6">
        <nav aria-label="breadcrumb" class="mb-8">
            {%- from "components/breadcrumbs.njk" import breadcrumbs -%}
            {% set crumbs = page.url | breadcrumbs %}
            {{ breadcrumbs(crumbs) }}
        </nav>
        <div class="max-w-3xl">
            <span class="inline-block px-4 py-1.5 bg-primary/10 text-primary text-sm font-medium rounded-full mb-6">
                Maschinenübersicht
            </span>
            <h1 class="font-headline font-semibold text-4xl sm:text-4xl md:text-5xl text-foreground-headline mb-6 tracking-tight hyphens-auto break-words">
                Bereiche und Unterbereiche
            </h1>
            <p class="text-foreground-muted text-lg md:text-xl max-w-2xl font-light">
                Eine kompakte Übersicht aller Verpackungsmaschinen, gruppiert nach Hauptbereich und Unterbereich.
            </p>
        </div>
    </div>
</section>

<section class="py-12 md:py-16 bg-background">
    <div class="max-w-8xl mx-auto px-6">
        <div class="space-y-4">
            {% for sector in categories.categories %}
                <section class="grid gap-4 border border-border-light bg-card p-5 shadow-soft md:grid-cols-[16rem_minmax(0,1fr)] md:p-6">
                    <div>
                        <div class="flex items-center gap-3">
                            <div class="size-10 shrink-0 rounded-md bg-primary/10 text-primary flex items-center justify-center">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="lucide lucide-package size-5"><path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"></path><path d="M12 22V12"></path><path d="m3.3 7 7.703 4.734a2 2 0 0 0 1.994 0L20.7 7"></path><path d="m7.5 4.27 9 5.15"></path>
                                </svg>
                            </div>
                            <div>
                                <h2 class="font-headline text-xl font-semibold text-foreground-headline">
                                    {{ sector.name | safe }}
                                </h2>
                                <p class="text-sm text-foreground-muted">
                                    {{ sector.machines_count }}
                                    {% if sector.machines_count == 1 %}Maschine{% else %}Maschinen{% endif %}
                                </p>
                            </div>
                        </div>
                        {% if sector["sub-categories"] and sector["sub-categories"].length > 1 %}
                            <a href="{{ ("/maschinen/" ~ sector.url ~ "/") | url }}" class="mt-4  items-center gap-1.5 text-sm font-semibold text-primary hover:text-link hidden">
                                Bereichsseite
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="lucide lucide-arrow-right size-3.5"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
                                </svg>
                            </a>
                        {% endif %}
                    </div>
                    <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
                        {% for group in machines.list %}
                            {% if group.parent_category == sector.name %}
                                <a href="{{ ("/" ~ group.slug ~ "/") | url }}" class="group flex items-center justify-between gap-3 border border-border bg-background px-4 py-3 transition-colors hover:border-primary/30 hover:bg-secondary">
                                    <span class="min-w-0">
                                        <span class="block truncate text-sm font-semibold text-secondary-foreground group-hover:text-primary">
                                            {{ group.title | safe }}
                                        </span>
                                        <span class="mt-0.5 block text-xs text-foreground-muted">
                                            {{ group.machines | length }}
                                            {% if group.machines | length == 1 %}Maschine{% else %}Maschinen{% endif %}
                                        </span>
                                    </span>
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="lucide lucide-arrow-right size-4 shrink-0 text-primary transition-transform group-hover:translate-x-1"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
                                    </svg>
                                </a>
                            {% endif %}
                        {% endfor %}
                    </div>
                </section>
            {% endfor %}
        </div>
    </div>
</section>

<section class="py-16 section-gradient-light">
    <div class="max-w-8xl mx-auto px-6">
        <div class="max-w-3xl">
            <h2 class="font-headline text-3xl md:text-4xl text-foreground-headline font-semibold mb-4">
                Nicht gefunden, wonach Sie suchen?
            </h2>
            <p class="text-foreground-muted text-base mb-6">
                Wir unterstützen Sie dabei, die optimale Verpackungslösung für Ihre individuellen Anforderungen zu finden.
            </p>
            <a class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-6 py-3 rounded-full font-medium hover:bg-primary/90 transition-all shadow-soft hover:shadow-hover" href="{{ "/Kontakt/" | url }}">
                Kontaktieren
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-arrow-right w-5 h-5"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
                </svg>
            </a>
        </div>
    </div>
</section>
